#!/usr/bin/env bash
# game-translate — Traductor de juegos en tiempo real (nativo Wayland/Hyprland)
# Captura una región de pantalla, hace OCR y la traduce; muestra el resultado en
# una notificación (texto corto) o en un popup desplazable (texto largo).
#
# Uso:
#   game-translate translate [imagen]   captura región (o usa 'imagen'), OCR + traduce
#   game-translate ocr       [imagen]   captura región (o usa 'imagen'), solo OCR (copia)
#   game-translate full                  captura PANTALLA COMPLETA y traduce
# Sin argumento de imagen usa grim+slurp para seleccionar una región.
#
# Configuración (precedencia: variable de entorno > archivo de config > por defecto):
#   ~/.config/game-translate/config  con líneas tipo  SL=en  / TL=es  / OCR_LANG=eng
#   o variables  GAME_TRANSLATE_SL / GAME_TRANSLATE_TL / GAME_TRANSLATE_OCR_LANG
#     SL       idioma origen (código Google Translate, p.ej. en, ja, fr)
#     TL       idioma destino (código Google Translate, p.ej. es)
#     OCR_LANG idioma del OCR (código Tesseract: inglés='eng', japonés='jpn'...)

set -uo pipefail

# --- Configuración ---
CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/game-translate/config"
[ -f "$CONFIG" ] && . "$CONFIG"
SL="${GAME_TRANSLATE_SL:-${SL:-en}}"
TL="${GAME_TRANSLATE_TL:-${TL:-es}}"
OCR_LANG="${GAME_TRANSLATE_OCR_LANG:-${OCR_LANG:-eng}}"
POPUP_THRESHOLD="${GAME_TRANSLATE_THRESHOLD:-300}"

MODE="${1:-translate}"
IMG_ARG="${2:-}"

TMP=""
cleanup() { [ -n "$TMP" ] && rm -f "$TMP"; }
trap cleanup EXIT

notify() { notify-send "$@" 2>/dev/null || true; }

# --- 1) Conseguir la imagen ---
if [ -n "$IMG_ARG" ] && [ -f "$IMG_ARG" ]; then
  SRC="$IMG_ARG"
else
  TMP="$(mktemp --suffix=.png)"
  SRC="$TMP"
  if [ "$MODE" = "full" ]; then
    grim "$SRC" 2>/dev/null || { notify -u critical "Traductor" "Fallo al capturar la pantalla"; exit 1; }
    MODE="translate"
  else
    # selección de región; si se cancela (Esc), slurp devuelve != 0
    REGION="$(slurp 2>/dev/null)" || exit 0
    grim -g "$REGION" "$SRC" 2>/dev/null || { notify -u critical "Traductor" "Fallo al capturar la región"; exit 1; }
  fi
fi

# --- 2) OCR ---
TEXT="$(tesseract "$SRC" stdout -l "$OCR_LANG" --psm 6 2>/dev/null \
        | tr '\n' ' ' | tr -s ' ' | sed 's/^ //; s/ $//')"

if [ -z "$TEXT" ]; then
  notify -u low "Traductor" "No se detectó texto en la región"
  exit 0
fi

if [ "$MODE" = "ocr" ]; then
  printf '%s' "$TEXT" | wl-copy
  notify "📋 OCR (copiado)" "$TEXT"
  exit 0
fi

# --- 3) Traducción (endpoint gratuito de Google, sin clave) ---
TR="$(curl -s --max-time 15 -G "https://translate.googleapis.com/translate_a/single" \
        --data-urlencode "q=$TEXT" \
        --data "client=gtx" --data "sl=$SL" --data "tl=$TL" --data "dt=t" \
      | python3 -c 'import sys,json
try:
    d=json.load(sys.stdin); print("".join(s[0] for s in d[0] if s and s[0]))
except Exception:
    pass' 2>/dev/null)"

if [ -z "$TR" ]; then
  notify -u critical "Traductor" "Error de traducción (¿sin conexión?)\n\nOriginal:\n$TEXT"
  exit 1
fi

# --- 4) Mostrar y copiar ---
printf '%s' "$TR" | wl-copy

if [ "${#TR}" -le "$POPUP_THRESHOLD" ]; then
  # Notificación: título corto fijo; traducción grande y completa en el cuerpo
  # (multilínea), original más pequeño debajo.
  notify -t 0 "🌐 Traducción" "<span size='120%'>$TR</span>
<span size='88%'>🔤 $TEXT</span>"
else
  # Texto largo: popup zenity desplazable con el texto íntegro.
  if command -v zenity >/dev/null; then
    printf '%s\n\n──────────────\n🔤 %s\n' "$TR" "$TEXT" \
      | setsid zenity --text-info --width=780 --height=500 \
          --title="🌐 Traducción" --font="Sans 13" >/dev/null 2>&1 &

    # Las windowrules de Hyprland no enganchan con zenity; flotar/centrar a mano.
    if command -v hyprctl >/dev/null; then
      ( for _ in $(seq 1 30); do
          if hyprctl clients -j 2>/dev/null | grep -q '"class": *"zenity"'; then
            hyprctl dispatch togglefloating class:zenity >/dev/null 2>&1
            hyprctl dispatch resizewindowpixel "exact 780 520,class:zenity" >/dev/null 2>&1
            hyprctl dispatch movewindowpixel "exact 570 280,class:zenity" >/dev/null 2>&1
            break
          fi
          sleep 0.1
        done ) &
    fi
  else
    # Sin zenity: notificación (puede truncarse) como respaldo.
    notify -t 0 "🌐 Traducción" "<span size='110%'>$TR</span>"
  fi
fi
